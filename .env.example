# Copy to `.env` and adjust. Restart Expo after changes: npx expo start -c
#
# ─── CS153 / expo-go demo (recommended) ───
# Copy .env.demo to .env OR set:
#   EXPO_PUBLIC_DEMO_MODE=true
# No Supabase or OpenAI keys needed. Uses mock startups, diligence, leaderboard, profile.
#
# ─── Optional: Supabase (real auth + cloud sync) ───
# EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
#
# ─── Optional: OpenAI (real AI diligence on Submit) ───
# OPENAI_API_KEY=sk-your-openai-key

EXPO_PUBLIC_DEMO_MODE=true

# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=
# OPENAI_API_KEY=
